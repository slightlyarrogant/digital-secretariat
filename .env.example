# Non-secret application policy. Store production secrets in root-owned files,
# never in this file and never in the repository.
SECRETARIAT_ALLOWED_LOGINS=owner@example.com
SECRETARIAT_TRUSTED_PROXY_IPS=127.0.0.1,::1
SECRETARIAT_RLS_USER_ID=1
SECRETARIAT_DEFAULT_FROM_ADDRESS=office@example.com
SECRETARIAT_DRAFT_ACTIONS_ENABLED=false
SECRETARIAT_REPLY_ACTIONS_ENABLED=false
SECRETARIAT_OUTBOUND_FREEZE=true
SECRETARIAT_FREEZE_ALLOWED_DOMAINS=@example.com
SECRETARIAT_FREEZE_ALLOWED_ADDRESSES=owner@example.com
ENVIRONMENT=production
